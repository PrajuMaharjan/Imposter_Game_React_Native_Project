{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "paths": {
      "*": [
        "./*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@store/*": [
        "./store/*"
      ],
      "@constants/*": [
        "./constants/*"
      ],
      "@screens/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts"
,     "App.js"  ]
}
